# ─── Required ────────────────────────────────────────────────────────────────
# Get these from https://my.telegram.org/apps
API_ID=
API_HASH=

# Get this from @BotFather
BOT_TOKEN=

# Generate with session-string.py
SESSION_STRING=

# Comma-separated Telegram user IDs — these users can run owner-only commands
# and receive lifecycle reminders. Find your ID by messaging @userinfobot
# Example: OWNER_IDS=123456789,987654321
OWNER_IDS=

# ─── Optional (defaults shown) ───────────────────────────────────────────────
MAX_CONCURRENT_DOWNLOADS=1
MAX_CONCURRENT_UPLOADS=1
MAX_CONCURRENT_TRANSMISSIONS=2
BATCH_SIZE=1
FLOOD_WAIT_DELAY=15
